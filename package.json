{
  "name": "playground-app-server",
  "version": "1.0.0",
  "description": "Backend server for the Playground Information App",
  "main": "src/index.js",
  "scripts": {
    "start": "node server/src/index.js",
    "test": "npm run test:go-live",
    "test:server": "npm --prefix server test",
    "test:server:ci": "npm --prefix server run test:ci",
    "test:server:integration": "npm --prefix server run test:integration",
    "test:website": "npm --prefix website test",
    "build:website": "npm --prefix website run build",
    "test:compose": "node scripts/run-compose-test.cjs",
    "test:go-live": "npm run test:server:ci && npm run test:website && npm run build:website && npm run test:compose"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.7.0",
    "@google-cloud/vision": "^5.3.4",
    "@google/genai": "^1.45.0",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "gradle": "^1.2.4",
    "mongodb": "^6.3.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.34.5"
  }
}
