{
  "name": "playground-app-server",
  "version": "1.0.0",
  "description": "Backend server for Play Spotter app",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "jest --runInBand --testPathIgnorePatterns=/integration/",
    "test:all": "jest --runInBand",
    "test:unit": "jest --runInBand --testPathIgnorePatterns=/integration/",
    "test:integration": "jest --runInBand --testPathPattern=integration",
    "test:ci": "jest --runInBand --detectOpenHandles --coverage --testPathIgnorePatterns=/integration/",
    "test:ci:full": "jest --runInBand --detectOpenHandles --coverage",
    "test:coverage": "jest --runInBand --coverage --testPathIgnorePatterns=/integration/",
    "test:watch": "jest --watch",
    "seed": "node seed_database.js",
    "migrate": "node scripts/migrate.js",
    "cleanup:region": "node scripts/cleanupRegion.js",
    "reset:seed:geo": "node scripts/resetSeedGeo.js",
    "recategorize:types": "node scripts/recategorizePlaygroundTypes.js",
    "sync:web-brand-icon": "node scripts/syncWebsiteAppIcon.js"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.7.0",
    "@google-cloud/vision": "^4.0.2",
    "@google/genai": "^0.7.0",
    "axios": "^1.6.8",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "morgan": "^1.10.0",
    "firebase-admin": "^12.1.0",
    "mongodb": "^6.3.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "sharp": "^0.33.3",
    "stripe": "^21.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
